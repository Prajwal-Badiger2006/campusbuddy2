# ══════════════════════════════════════════════
# CAMPUS BUDDY — Environment Configuration
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!


# ── Gemini API Key (Cloud Vision OCR) ──
# Used by GeminiVisionService to extract student ID data during ID scanning.
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ── Firebase Configuration ──
# These values come from your Firebase project console.
# The google-services.json file is auto-generated from these.
# If you're setting up a new Firebase project, update these accordingly.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_APP_ID=your_firebase_app_id
